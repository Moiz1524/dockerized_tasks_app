<%= turbo_frame_tag dom_id(task) do %>
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow duration-200 p-5"
       data-controller="task-copy"
       data-task-copy-title-value="<%= task.title %>"
       data-task-copy-description-value="<%= task.description.to_s %>">
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 flex-wrap mb-1">
          <span class="<%= priority_badge_class(task.priority) %> text-xs font-semibold px-2 py-0.5 rounded-full">
            <%= task.priority.capitalize %>
          </span>
          <span class="<%= status_badge_class(task.status) %> text-xs font-semibold px-2 py-0.5 rounded-full">
            <%= task.status.humanize %>
          </span>
          <% if task.due_date.present? %>
            <span class="<%= task.due_date.past? ? 'text-red-500' : 'text-gray-400' %> text-xs flex items-center gap-1">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <%= task.due_date.strftime("%b %-d, %Y") %>
            </span>
          <% end %>
        </div>

        <h3 class="text-gray-900 font-semibold text-base leading-snug truncate"><%= task.title %></h3>

        <% if task.description.present? %>
          <p class="text-gray-500 text-sm mt-1 line-clamp-2"><%= task.description %></p>
        <% end %>
      </div>

      <div class="flex items-center gap-1 shrink-0">
        <button data-action="click->task-copy#copy"
                data-task-copy-target="button"
                class="inline-flex items-center gap-1 text-xs text-gray-500 hover:text-indigo-600 bg-gray-50 hover:bg-indigo-50 border border-gray-200 hover:border-indigo-200 px-2 py-1 rounded-lg transition-colors duration-150"
                title="Copy task details to clipboard">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          <span data-task-copy-target="label">Copy</span>
        </button>

        <%= link_to edit_task_path(task),
              class: "inline-flex items-center gap-1 text-xs text-gray-500 hover:text-indigo-600 bg-gray-50 hover:bg-indigo-50 border border-gray-200 hover:border-indigo-200 px-2 py-1 rounded-lg transition-colors duration-150" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Edit
        <% end %>

        <%= button_to copy_task_path(task),
              method: :post,
              class: "inline-flex items-center gap-1 text-xs text-gray-500 hover:text-emerald-600 bg-gray-50 hover:bg-emerald-50 border border-gray-200 hover:border-emerald-200 px-2 py-1 rounded-lg transition-colors duration-150",
              title: "Duplicate this task" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          Duplicate
        <% end %>

        <%= button_to task_path(task),
              method: :delete,
              data: { turbo_confirm: "Delete \"#{task.title}\"?" },
              class: "inline-flex items-center gap-1 text-xs text-gray-500 hover:text-red-600 bg-gray-50 hover:bg-red-50 border border-gray-200 hover:border-red-200 px-2 py-1 rounded-lg transition-colors duration-150" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          Delete
        <% end %>
      </div>
    </div>
  </div>
<% end %>
