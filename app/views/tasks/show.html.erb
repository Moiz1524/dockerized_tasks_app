<% content_for :title, @task.title %>

<div class="w-full max-w-2xl mx-auto">
  <div class="mb-4">
    <%= link_to "← Back to tasks", tasks_path, class: "text-sm text-indigo-600 hover:text-indigo-800 font-medium transition" %>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
    <div class="flex items-center gap-2 mb-3">
      <span class="<%= priority_badge_class(@task.priority) %> text-xs font-semibold px-2 py-0.5 rounded-full">
        <%= @task.priority.capitalize %>
      </span>
      <span class="<%= status_badge_class(@task.status) %> text-xs font-semibold px-2 py-0.5 rounded-full">
        <%= @task.status.humanize %>
      </span>
      <% if @task.due_date.present? %>
        <span class="<%= @task.due_date.past? ? 'text-red-500' : 'text-gray-400' %> text-xs">
          Due <%= @task.due_date.strftime("%b %-d, %Y") %>
        </span>
      <% end %>
    </div>

    <h1 class="text-2xl font-bold text-gray-900 mb-3"><%= @task.title %></h1>

    <% if @task.description.present? %>
      <p class="text-gray-600 leading-relaxed"><%= @task.description %></p>
    <% end %>

    <div class="flex items-center gap-3 mt-6 pt-4 border-t border-gray-100">
      <%= link_to "Edit", edit_task_path(@task), class: "px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition" %>
      <%= button_to "Delete", task_path(@task), method: :delete,
            data: { turbo_confirm: "Delete this task?" },
            class: "px-4 py-2 bg-red-50 text-red-700 text-sm font-semibold rounded-lg hover:bg-red-100 border border-red-200 transition" %>
    </div>
  </div>
</div>
